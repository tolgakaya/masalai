{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(npm show:*)",
      "Bash(npx prisma:*)",
      "Bash(docker compose:*)",
      "Bash(corepack:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(yarn:*)",
      "Bash(bun install:*)",
      "Edit(docs/adr/**)",
      "Write(docs/adr/**)",
      "Edit(**/prisma/migrations/**)",
      "Edit(docs/state/DECISIONS.md)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/precompact.mjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/shared-typecheck.mjs" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/stop-state-reminder.mjs" }
        ]
      }
    ]
  }
}

# MasalAI — environment template. Copy to `.env.local` and adjust as needed.
# Values below match docker-compose.dev.yml (engineering-handbook §306) and are
# DEV-ONLY throwaways. Never commit real secrets — .env / .env.local are gitignored.
# Rule: every new env var lands here AND in the relevant apps/<x>/src/env.ts zod
# schema in the same PR (root CLAUDE.md hard rules).

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
# Provider mode: 'mock' generates stories locally with fixtures; 'live' calls real vendors.
PROVIDERS=mock

# --- Ports -------------------------------------------------------------------
# Railway injects PORT per-service; services bind 0.0.0.0:${PORT}
# (railway-deployment.md §3.2). Local defaults: api 8080, web 3000.
# Uncomment to pin the api port locally:
# PORT=8080

# --- Postgres (docker-compose: postgres) -------------------------------------
DATABASE_URL=postgresql://masalai:masalai@localhost:5432/masalai_dev

# --- Redis / BullMQ (docker-compose: redis) ----------------------------------
REDIS_URL=redis://localhost:6379

# --- Object storage: MinIO locally, Cloudflare R2 in staging/prod ------------
# S3-compatible; path-style addressing is required for MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=masalai-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Email: Mailpit locally (SMTP :1025, web UI http://localhost:8025) -------
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=noreply@masalai.local
